# Scalp Bot / Zenith — variables de entorno
# Copia a .env y rellena. NO commitear .env.

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Bot dev separado (F6). BOT_MODE=DEV → usa *_DEV vars + fuerza EXECUTION_MODE=PAPER.
BOT_MODE=PROD
# TELEGRAM_TOKEN_DEV=
# TELEGRAM_CHAT_ID_DEV=

# ── Exchange ─────────────────────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# PAPER = simula órdenes sin tocar Binance real. LIVE = trading real.
EXECUTION_MODE=PAPER

# ── AI providers ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ── Loop interval ────────────────────────────────────────────────────────────
CHECK_INTERVAL=35

# ── Webhook TradingView (Fase 1) ─────────────────────────────────────────────
# Secret compartido con TradingView para firma HMAC SHA256 del payload.
# Generar 32 bytes random: python -c "import secrets; print(secrets.token_hex(32))"
TV_WEBHOOK_SECRET=

# Segundo factor: token en path /webhook/tradingview/<TV_WEBHOOK_TOKEN>.
# Útil cuando TradingView Pine no puede computar HMAC (plan free).
# Generar: python -c "import secrets; print(secrets.token_urlsafe(24))"
TV_WEBHOOK_TOKEN=

# Enforce HMAC=true rechaza requests sin firma válida (ni token). Default false (canary).
ENFORCE_HMAC=false

# Rate limit por IP (requests por minuto). Default 10.
TV_RATE_LIMIT_PER_MIN=10
